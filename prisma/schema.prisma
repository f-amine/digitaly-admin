generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FREE_USER
  PRO_MEMBER
  PARTNER
}

enum Difficulty {
  BEGINNER
  FAST_LAUNCH
  ADVANCED
}

enum LicenseType {
  SHARED
  EXCLUSIVE
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(FREE_USER)
  freeLicenseAvailable Int @default(1)
  kitsClaimedThisPeriod Int @default(0)
  kitPeriodStart        DateTime?
  extraKits             Int @default(0)
  onboardingCompleted  Boolean @default(false)
  experienceLevel      String?  // "first_time", "some_experience", "experienced"
  sellingPlatforms     String[] @default([])
  interestedNiches     String[] @default([])
  primaryGoal          String?  // "side_income", "full_time", "learn", "grow_existing"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]
  posts         Post[]
  licenses      UserLicense[]
  savedProducts SavedProduct[]
  integrations     Integration[]
  generatedContent GeneratedContent[]
  partner          Partner?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Post {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

model Product {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  description     String
  shortDescription String
  image           String?
  isFreeProduct   Boolean    @default(false)
  totalLicenses   Int        @default(100)
  claimedLicenses Int        @default(0)
  category        String     @default("general")
  featured        Boolean    @default(false)
  difficulty      Difficulty @default(BEGINNER)
  sellingPlatforms String[]  @default([])
  languages       String[]   @default([])
  demandLabel     String?    // "trending", "high_demand", "beginner_friendly", "new"
  exclusiveLicensePrice Float?
  exclusiveLicenseSold  Boolean @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  assets   ProductAsset[]
  licenses UserLicense[]
  savedBy  SavedProduct[]

  @@index([slug])
  @@index([isFreeProduct])
  @@index([category])
  @@index([difficulty])
}

model ProductAsset {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  type      String // product_file, canva_template, marketing_kit, sales_copy, branding_kit
  fileUrl   String
  fileSize  String?
  createdAt DateTime @default(now())

  @@index([productId])
}

model UserLicense {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  licenseType LicenseType @default(SHARED)
  claimedAt   DateTime    @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // "lightfunnels", "shopify", etc.
  accessToken  String
  refreshToken String?
  metadata     String?  // JSON — e.g. { "shop": "mystore.myshopify.com" }
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("integration")
}

model GeneratedContent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productName String
  contentType String
  tone        String
  platform    String?
  content     String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("generated_content")
}

model SavedProduct {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model PartnerApplication {
  id           String                   @id @default(cuid())
  fullName     String
  email        String
  socialHandle String
  socialLinks  Json?
  niche        String
  audienceSize Int                      @default(0)
  pitch        String
  status       PartnerApplicationStatus @default(PENDING)
  reviewNotes  String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime                 @default(now())
  partner      Partner?

  @@index([email])
  @@index([status])
  @@map("partner_application")
}

model Partner {
  id            String             @id @default(cuid())
  applicationId String             @unique
  application   PartnerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String?            @unique
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String             @unique
  fullName      String
  slug          String             @unique
  niche         String
  payoutMethod  String?
  payoutDetails Json?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  coupons       Coupon[]
  clicks        ReferralClick[]
  payouts       Payout[]

  @@index([active])
  @@map("partner")
}

model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique
  partnerId      String
  partner        Partner            @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  discountType   CouponDiscountType
  discountValue  Int
  active         Boolean            @default(true)
  expiresAt      DateTime?
  stripeCouponId String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  redemptions    CouponRedemption[]

  @@index([partnerId])
  @@map("coupon")
}

model CouponRedemption {
  id          String   @id @default(cuid())
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId      String?
  productId   String?
  orderRef    String?
  amountCents Int      @default(0)
  redeemedAt  DateTime @default(now())

  @@index([couponId, redeemedAt])
  @@map("coupon_redemption")
}

model ReferralClick {
  id          String   @id @default(cuid())
  partnerId   String
  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  ip          String?
  userAgent   String?
  referer     String?
  landingPath String?
  createdAt   DateTime @default(now())

  @@index([partnerId, createdAt])
  @@map("referral_click")
}

model Payout {
  id          String       @id @default(cuid())
  partnerId   String
  partner     Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  amountCents Int
  currency    String       @default("USD")
  status      PayoutStatus @default(PENDING)
  method      String
  reference   String?
  notes       String?
  paidAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([partnerId, createdAt])
  @@map("payout")
}
